# Gemini API Key (Get from https://aistudio.google.com/)
GEMINI_API_KEY=

# Server configuration
PORT=3000

# Scraping settings
SCRAPE_TIMEOUT_MS=30000
PLAYWRIGHT_ENABLED=true

# Gemini API limits (requests per minute)
GEMINI_RPM=8

# Verbose logging flag (true to enable detailed diagnostic logs)
VERBOSE_LOGGING=false

